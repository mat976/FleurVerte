{% extends 'base.html.twig' %}

{% block title %}Nos Fleurs - FleurVerte{% endblock %}

{% block javascripts %}
	{{ parent() }}
	<script src="{{ asset('js/product-preview.js') }}" defer></script>
{% endblock %}

{% block body %}
	{# Page Produits - Design léger et transparent #}
	<div class="min-h-screen bg-white relative overflow-hidden">
		{# Formes décoratives flottantes #}
		<div class="absolute inset-0 overflow-hidden pointer-events-none">
			<div class="absolute top-20 left-5 w-72 h-72 bg-green-100/30 rounded-full blur-3xl animate-float"></div>
			<div class="absolute top-40 right-10 w-96 h-96 bg-emerald-100/25 rounded-full blur-3xl animate-float-slow"></div>
			<div class="absolute bottom-60 left-1/4 w-64 h-64 bg-teal-100/20 rounded-full blur-3xl animate-float-delay"></div>
			<div class="absolute bottom-20 right-1/3 w-80 h-80 bg-green-50/30 rounded-full blur-3xl animate-pulse-soft"></div>
			{# Éléments floraux décoratifs #}
			<div class="absolute top-24 right-20 text-green-200/20 text-8xl animate-float">🌿</div>
			<div class="absolute top-1/3 left-10 text-emerald-100/15 text-7xl animate-float-slow">🌸</div>
			<div class="absolute bottom-40 right-16 text-green-100/20 text-6xl animate-pulse-soft">🌺</div>
			<div class="absolute bottom-1/4 left-1/3 text-teal-100/15 text-5xl animate-float-delay">🍃</div>
		</div>

		{# Header Section #}
		<section class="relative z-10 py-16">
			<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-16">
				<div class="text-center mb-10">
					<div class="inline-flex items-center gap-2 px-5 py-2 bg-green-50/80 backdrop-blur-sm rounded-full border border-green-100 mb-6">
						<i class="fas fa-seedling text-green-600"></i>
						<span class="text-green-700 font-medium text-sm">Collection fraîche</span>
					</div>
					<h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-4">Nos Fleurs</h1>
					<p class="text-lg text-gray-500 max-w-2xl mx-auto">Découvrez notre sélection de fleurs fraîches, soigneusement choisies par nos fleuristes partenaires.</p>
				</div>

				{# Barre de recherche moderne #}
				<div class="max-w-3xl mx-auto">
					{{ form_start(searchForm, {'attr': {'class': 'flex flex-col sm:flex-row gap-3'}}) }}
					<div class="flex-grow relative">
						<i class="fas fa-search absolute left-5 top-1/2 -translate-y-1/2 text-gray-400"></i>
						{{ form_widget(searchForm.search, {'attr': {'class': 'w-full pl-12 pr-4 py-4 rounded-2xl bg-white/80 backdrop-blur-sm border border-gray-200 focus:outline-none focus:ring-2 focus:ring-green-500 focus:border-transparent shadow-lg', 'placeholder': 'Rechercher une fleur...', 'value': search}}) }}
					</div>
					<div class="flex gap-3">
						{{ form_widget(searchForm.sort, {'attr': {'class': 'px-5 py-4 rounded-2xl bg-white/80 backdrop-blur-sm border border-gray-200 focus:outline-none focus:ring-2 focus:ring-green-500 shadow-lg'}, 'value': currentSort}) }}
						<button type="submit" class="bg-green-500 hover:bg-green-600 text-white px-8 py-4 rounded-2xl font-semibold transition-all shadow-lg hover:shadow-xl hover:-translate-y-0.5">
							Rechercher
						</button>
					</div>
					{{ form_end(searchForm) }}
				</div>
			</div>
		</section>

		{# Produits Grid #}
		<section class="relative z-10 pb-20">
			<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-16">
				{# Résultats count #}
				<div class="flex items-center justify-center gap-6 mb-10">
					<div class="flex items-center gap-2 px-5 py-2.5 bg-white/60 backdrop-blur-sm rounded-xl border border-white/50 shadow">
						<i class="fas fa-leaf text-green-600"></i>
						<span class="font-semibold text-gray-700">{{ fleurs|length }} fleurs disponibles</span>
					</div>
				</div>

			{# Grid de produits #}
			<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
				{% for fleur in fleurs %}
					<div class="group bg-white/80 backdrop-blur-sm rounded-3xl shadow-lg hover:shadow-2xl transition-all duration-500 overflow-hidden border border-white/50 hover:-translate-y-2"
						data-preview
						data-preview-image="{{ asset(fleur.getImageUrl()) }}"
						data-preview-name="{{ fleur.nom }}"
						data-preview-desc="{{ fleur.description|slice(0, 200) }}"
						data-preview-price="{{ fleur.isEnPromo ? fleur.prixPromo|number_format(2, ',', ' ') : fleur.prix|number_format(2, ',', ' ') }}"
						data-preview-old-price="{{ fleur.prix|number_format(2, ',', ' ') }}"
						data-preview-promo="{{ fleur.isEnPromo ? 'true' : 'false' }}"
						data-preview-percent="{{ fleur.promoPercent }}"
						data-preview-stock="{{ fleur.stockLabel }}"
						data-preview-rating="{{ fleur.noteMoyenne is not null ? fleur.noteMoyenne ~ '/5 (' ~ fleur.nombreCommentaires ~ ' avis)' : 'Aucun avis' }}"
						data-preview-url="{{ path('product_detail', {'id': fleur.id}) }}"
						data-preview-tags="{{ fleur.tags|map(t => {name: t.nom, color: t.couleur, textColor: t.textColor})|json_encode|e('html_attr') }}"
					>
						{# Image avec overlay #}
						<div class="relative h-56 overflow-hidden">
							<a href="{{ path('product_detail', {'id': fleur.id}) }}">
								<img src="{{ asset(fleur.getImageUrl()) }}" alt="{{ fleur.nom }}" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700">
							</a>
							
							{# Badge stock #}
							<div class="absolute top-4 left-4">
								<span class="px-3 py-1 text-xs font-semibold rounded-full backdrop-blur-sm
									{% if fleur.stockStatus == 'out_of_stock' %}
										bg-red-500/90 text-white
									{% elseif fleur.stockStatus == 'low_stock' %}
										bg-orange-500/90 text-white
									{% elseif fleur.stockStatus == 'medium_stock' %}
										bg-yellow-500/90 text-white
									{% else %}
										bg-green-500/90 text-white
									{% endif %}">
									{{ fleur.stockLabel }}
								</span>
							</div>

							{# Badge promo #}
							{% if fleur.isEnPromo %}
								<div class="absolute top-4 right-4">
									<span class="px-3 py-1.5 bg-red-500 text-white text-xs font-bold rounded-full shadow-lg animate-pulse">
										-{{ fleur.promoPercent }}%
									</span>
								</div>
							{% endif %}

							{# Quick actions overlay #}
							<div class="absolute inset-0 bg-black/40 opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-center justify-center gap-3">
								<a href="{{ path('product_detail', {'id': fleur.id}) }}" class="w-12 h-12 bg-white rounded-full flex items-center justify-center text-gray-800 hover:bg-green-600 hover:text-white transition-colors shadow-lg">
									<i class="fas fa-eye"></i>
								</a>
								{% if is_granted('ROLE_USER') and fleur.stock > 0 %}
									<form action="{{ path('app_cart_add', {'id': fleur.id}) }}" method="POST">
										<button type="submit" class="w-12 h-12 bg-white rounded-full flex items-center justify-center text-gray-800 hover:bg-green-600 hover:text-white transition-colors shadow-lg">
											<i class="fas fa-shopping-bag"></i>
										</button>
									</form>
								{% endif %}
							</div>
						</div>

						{# Content #}
						<div class="p-5">
							{# Tags #}
							{% if fleur.tags|length > 0 %}
								<div class="flex flex-wrap gap-1 mb-3">
									{% for tag in fleur.tags|slice(0, 3) %}
										<a href="{{ path('app_search', {'tag': tag.id}) }}" class="px-2 py-0.5 rounded-full text-xs font-medium transition-opacity hover:opacity-80" style="background-color: {{ tag.couleur }}; color: {{ tag.textColor ?? '#ffffff' }};">
											{{ tag.nom }}
										</a>
									{% endfor %}
									{% if fleur.tags|length > 3 %}
										<span class="px-2 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-600">+{{ fleur.tags|length - 3 }}</span>
									{% endif %}
								</div>
							{% endif %}

							{# Nom #}
							<a href="{{ path('product_detail', {'id': fleur.id}) }}">
								<h3 class="font-bold text-lg text-gray-900 mb-2 hover:text-green-600 transition-colors">{{ fleur.nom }}</h3>
							</a>

							{# Description #}
							<p class="text-gray-500 text-sm mb-4 line-clamp-2">{{ fleur.description|slice(0, 80) }}{% if fleur.description|length > 80 %}...{% endif %}</p>

							{# Rating #}
							{% if fleur.noteMoyenne is not null %}
								<div class="flex items-center gap-2 mb-4">
									<div class="flex">
										{% for i in 1..5 %}
											{% if i <= fleur.noteMoyenne %}
												<span class="text-yellow-400">★</span>
											{% else %}
												<span class="text-gray-200">★</span>
											{% endif %}
										{% endfor %}
									</div>
									<span class="text-sm text-gray-500">({{ fleur.nombreCommentaires }} avis)</span>
								</div>
							{% endif %}

							{# Prix et bouton #}
							<div class="flex items-center justify-between pt-4 border-t border-gray-100">
								<div>
									{% if fleur.isEnPromo %}
										<span class="text-xs line-through text-gray-400 block">{{ fleur.prix|number_format(2, ',', ' ') }}€</span>
										<span class="text-xl font-bold text-gray-900">{{ fleur.prixPromo|number_format(2, ',', ' ') }}€</span>
										<span class="text-xs text-emerald-600 font-medium">-{{ fleur.economie|number_format(2, ',', ' ') }}€</span>
									{% else %}
										<span class="text-xl font-bold text-gray-900">{{ fleur.prix|number_format(2, ',', ' ') }}€</span>
									{% endif %}
								</div>
								<a href="{{ path('product_detail', {'id': fleur.id}) }}" class="bg-green-600 hover:bg-green-700 text-white px-5 py-2.5 rounded-full font-semibold text-sm transition-colors">
									Voir détails
								</a>
							</div>
						</div>
					</div>
				{% else %}
					<div class="col-span-full">
						<div class="max-w-lg mx-auto text-center bg-white/70 backdrop-blur-sm rounded-3xl p-12 border border-white/50 shadow-lg">
							<div class="w-20 h-20 bg-green-50 rounded-full flex items-center justify-center mx-auto mb-6">
								<i class="fas fa-seedling text-green-400 text-3xl"></i>
							</div>
							<h3 class="text-xl font-bold text-gray-900 mb-2">Aucune fleur trouvée</h3>
							<p class="text-gray-500 mb-6">Essayez de modifier vos critères de recherche.</p>
							<a href="{{ path('app_product') }}" class="inline-flex items-center gap-2 bg-green-500 hover:bg-green-600 text-white px-6 py-3 rounded-xl font-semibold transition-all hover:shadow-lg">
								<i class="fas fa-leaf"></i>
								Voir toutes les fleurs
							</a>
						</div>
					</div>
				{% endfor %}
			</div>
			</div>
		</section>
	</div>

	{# Modal de prévisualisation au survol — carte flottante centrée #}
	<div id="product-preview-modal"
		class="fixed top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 z-50 opacity-0 scale-95 pointer-events-none transition-all duration-300 ease-out w-full max-w-lg mx-auto">
		<div class="bg-white rounded-3xl shadow-2xl overflow-hidden border border-gray-100" id="product-preview-card">
			<div class="relative h-56 overflow-hidden">
				<img data-preview-image src="" alt="" class="w-full h-full object-cover">
				<div data-preview-badge class="absolute top-4 right-4 px-3 py-1.5 bg-rose-500 text-white text-sm font-bold rounded-full shadow-lg hidden"></div>
			</div>
			<div class="p-6">
				<div data-preview-tags class="flex flex-wrap gap-1.5 mb-3"></div>
				<h3 data-preview-name class="text-2xl font-bold text-gray-900 mb-2"></h3>
				<p data-preview-desc class="text-gray-500 text-sm leading-relaxed mb-4 line-clamp-3"></p>
				<div class="flex items-center gap-3 mb-3">
					<span class="text-sm text-gray-500"><i class="fas fa-box mr-1"></i><span data-preview-stock></span></span>
					<span class="text-gray-300">|</span>
					<span class="text-sm text-gray-500"><i class="fas fa-star text-yellow-400 mr-1"></i><span data-preview-rating></span></span>
				</div>
				<div class="flex items-center justify-between pt-4 border-t border-gray-100">
					<div class="flex items-baseline gap-2">
						<span data-preview-old-price class="text-sm line-through text-gray-400 hidden"></span>
						<span data-preview-price class="text-2xl font-bold text-gray-900"></span>
						<span data-preview-promo class="text-xs text-emerald-600 font-medium hidden">promo</span>
					</div>
					<a data-preview-link href="#" class="bg-green-600 hover:bg-green-700 text-white px-6 py-2.5 rounded-full font-semibold text-sm transition-colors">
						Voir détails
					</a>
				</div>
			</div>
		</div>
	</div>
{% endblock %}
