{% extends 'base.html.twig' %}

{% block title %}Administration — Logs{% endblock %}

{% block body %}
<div class="min-h-screen bg-gray-50 py-12">
	<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

		{# Header #}
		<div class="mb-8 flex flex-col md:flex-row md:items-center md:justify-between gap-4">
			<div>
				<div class="inline-flex items-center gap-2 px-4 py-2 bg-indigo-100 text-indigo-800 rounded-full text-sm font-medium mb-3">
					<i class="fas fa-shield-alt"></i> Administration
				</div>
				<h1 class="text-4xl font-bold text-gray-900">Logs système</h1>
				<p class="text-gray-500 mt-1">Historique des 200 dernières actions enregistrées.</p>
			</div>
			<a href="{{ path('app_admin_index') }}" class="inline-flex items-center gap-2 px-4 py-2 bg-white border border-gray-200 rounded-xl text-sm font-medium text-gray-700 hover:bg-gray-50 transition">
				<i class="fas fa-arrow-left"></i> Dashboard
			</a>
		</div>

		{# Table logs #}
		<div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden">
			{% if logs is empty %}
				<div class="p-16 text-center text-gray-400">
					<i class="fas fa-list-alt text-5xl mb-4"></i>
					<p class="text-lg">Aucun log enregistré.</p>
					<p class="text-sm mt-2">Les logs apparaîtront ici dès que des actions seront tracées via <code>ActionLog</code>.</p>
				</div>
			{% else %}
				<div class="overflow-x-auto">
					<table class="min-w-full divide-y divide-gray-100">
						<thead class="bg-gray-50">
							<tr>
								<th class="px-5 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Date</th>
								<th class="px-5 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Utilisateur</th>
								<th class="px-5 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Action</th>
								<th class="px-5 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">IP</th>
								<th class="px-5 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Détails</th>
							</tr>
						</thead>
						<tbody class="divide-y divide-gray-100 font-mono text-sm">
							{% for log in logs %}
								<tr class="hover:bg-gray-50 transition">
									<td class="px-5 py-3 text-gray-500 whitespace-nowrap">{{ log.createdAt|date('d/m/Y H:i:s') }}</td>
									<td class="px-5 py-3">
										{% if log.user %}
											<span class="font-medium text-gray-800">{{ log.user.username }}</span>
										{% else %}
											<span class="text-gray-400 italic">Anonyme</span>
										{% endif %}
									</td>
									<td class="px-5 py-3">
										<span class="inline-flex items-center px-2 py-0.5 rounded bg-gray-100 text-gray-700 text-xs">
											{{ log.action }}
										</span>
									</td>
									<td class="px-5 py-3 text-gray-500">{{ log.ip ?? '—' }}</td>
									<td class="px-5 py-3 text-gray-500 max-w-xs truncate">{{ log.details ?? '—' }}</td>
								</tr>
							{% endfor %}
						</tbody>
					</table>
				</div>
			{% endif %}
		</div>

	</div>
</div>
{% endblock %}
