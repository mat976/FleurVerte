{% extends 'base.html.twig' %}

{% block title %}Administration — Commentaires{% endblock %}

{% block body %}
<div class="min-h-screen bg-gray-50 py-12">
	<div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">

		{# Header #}
		<div class="mb-8 flex flex-col md:flex-row md:items-center md:justify-between gap-4">
			<div>
				<div class="inline-flex items-center gap-2 px-4 py-2 bg-indigo-100 text-indigo-800 rounded-full text-sm font-medium mb-3">
					<i class="fas fa-shield-alt"></i> Administration
				</div>
				<h1 class="text-4xl font-bold text-gray-900">Modération des commentaires</h1>
				<p class="text-gray-500 mt-1">Masquez ou supprimez les contenus inappropriés.</p>
			</div>
			<a href="{{ path('app_admin_index') }}" class="inline-flex items-center gap-2 px-4 py-2 bg-white border border-gray-200 rounded-xl text-sm font-medium text-gray-700 hover:bg-gray-50 transition">
				<i class="fas fa-arrow-left"></i> Dashboard
			</a>
		</div>

		{# Stats #}
		<div class="grid grid-cols-2 gap-4 mb-8">
			<div class="bg-green-50 border border-green-200 rounded-2xl p-5 flex items-center justify-between">
				<div>
					<p class="text-sm text-green-700">Visibles</p>
					<p class="text-3xl font-bold text-green-900">{{ visibles|length }}</p>
				</div>
				<i class="fas fa-eye text-green-400 text-3xl"></i>
			</div>
			<div class="bg-red-50 border border-red-200 rounded-2xl p-5 flex items-center justify-between">
				<div>
					<p class="text-sm text-red-700">Masqués</p>
					<p class="text-3xl font-bold text-red-900">{{ masques|length }}</p>
				</div>
				<i class="fas fa-eye-slash text-red-400 text-3xl"></i>
			</div>
		</div>

		{# Commentaires visibles #}
		<section class="bg-white rounded-2xl shadow-sm mb-8 overflow-hidden">
			<div class="px-6 py-4 bg-green-50 border-b border-green-200">
				<h2 class="text-xl font-bold text-green-900 flex items-center gap-2">
					<i class="fas fa-eye"></i>
					Commentaires visibles ({{ visibles|length }})
				</h2>
			</div>
			{% if visibles is empty %}
				<div class="p-10 text-center text-gray-400">
					<i class="fas fa-comment-slash text-4xl mb-3"></i>
					<p>Aucun commentaire visible.</p>
				</div>
			{% else %}
				<div class="divide-y divide-gray-100">
					{% for c in visibles %}
						<div class="p-5 hover:bg-gray-50 transition">
							<div class="flex flex-col md:flex-row md:items-start gap-4">
								<div class="flex-1">
									<div class="flex items-center gap-3 mb-2">
										<span class="font-semibold text-gray-800">{{ c.user.username }}</span>
										<span class="text-sm text-gray-400">—</span>
										<span class="text-sm text-gray-500">{{ c.fleur.nom ?? 'Fleur supprimée' }}</span>
										<div class="flex items-center gap-0.5 text-yellow-400 text-sm">
											{% for i in 1..5 %}
												<i class="fas fa-star{% if i > c.note %}-o{% endif %}"></i>
											{% endfor %}
										</div>
										<span class="text-xs text-gray-400">{{ c.dateCreation|date('d/m/Y H:i') }}</span>
									</div>
									<p class="text-gray-700">{{ c.contenu }}</p>
								</div>
								<div class="flex gap-2 flex-shrink-0">
									<form method="post" action="{{ path('app_admin_commentaire_masquer', {'id': c.id}) }}">
										<input type="hidden" name="_token" value="{{ csrf_token('admin_commentaire_' ~ c.id) }}">
										<button type="submit" class="inline-flex items-center gap-1 px-3 py-1.5 text-sm bg-yellow-100 text-yellow-800 rounded-lg hover:bg-yellow-200 transition">
											<i class="fas fa-eye-slash"></i> Masquer
										</button>
									</form>
									<form method="post" action="{{ path('app_admin_commentaire_supprimer', {'id': c.id}) }}" onsubmit="return confirm('Supprimer définitivement ce commentaire ?')">
										<input type="hidden" name="_token" value="{{ csrf_token('admin_commentaire_' ~ c.id) }}">
										<button type="submit" class="inline-flex items-center gap-1 px-3 py-1.5 text-sm bg-red-100 text-red-700 rounded-lg hover:bg-red-200 transition">
											<i class="fas fa-trash"></i> Supprimer
										</button>
									</form>
								</div>
							</div>
						</div>
					{% endfor %}
				</div>
			{% endif %}
		</section>

		{# Commentaires masqués #}
		<section class="bg-white rounded-2xl shadow-sm overflow-hidden">
			<div class="px-6 py-4 bg-red-50 border-b border-red-200">
				<h2 class="text-xl font-bold text-red-900 flex items-center gap-2">
					<i class="fas fa-eye-slash"></i>
					Commentaires masqués ({{ masques|length }})
				</h2>
			</div>
			{% if masques is empty %}
				<div class="p-10 text-center text-gray-400">
					<i class="fas fa-check-circle text-4xl mb-3"></i>
					<p>Aucun commentaire masqué.</p>
				</div>
			{% else %}
				<div class="divide-y divide-gray-100">
					{% for c in masques %}
						<div class="p-5 bg-red-50/30 hover:bg-red-50 transition">
							<div class="flex flex-col md:flex-row md:items-start gap-4">
								<div class="flex-1">
									<div class="flex items-center gap-3 mb-2">
										<span class="font-semibold text-gray-800">{{ c.user.username }}</span>
										<span class="text-sm text-gray-400">—</span>
										<span class="text-sm text-gray-500">{{ c.fleur.nom ?? 'Fleur supprimée' }}</span>
										<span class="text-xs text-gray-400">{{ c.dateCreation|date('d/m/Y H:i') }}</span>
									</div>
									<p class="text-gray-600 italic">{{ c.contenu }}</p>
								</div>
								<div class="flex gap-2 flex-shrink-0">
									<form method="post" action="{{ path('app_admin_commentaire_afficher', {'id': c.id}) }}">
										<input type="hidden" name="_token" value="{{ csrf_token('admin_commentaire_' ~ c.id) }}">
										<button type="submit" class="inline-flex items-center gap-1 px-3 py-1.5 text-sm bg-green-100 text-green-800 rounded-lg hover:bg-green-200 transition">
											<i class="fas fa-eye"></i> Réafficher
										</button>
									</form>
									<form method="post" action="{{ path('app_admin_commentaire_supprimer', {'id': c.id}) }}" onsubmit="return confirm('Supprimer définitivement ce commentaire ?')">
										<input type="hidden" name="_token" value="{{ csrf_token('admin_commentaire_' ~ c.id) }}">
										<button type="submit" class="inline-flex items-center gap-1 px-3 py-1.5 text-sm bg-red-100 text-red-700 rounded-lg hover:bg-red-200 transition">
											<i class="fas fa-trash"></i> Supprimer
										</button>
									</form>
								</div>
							</div>
						</div>
					{% endfor %}
				</div>
			{% endif %}
		</section>

	</div>
</div>
{% endblock %}
