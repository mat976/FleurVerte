{% extends 'base.html.twig' %}

{% block title %}Administration — Commandes{% endblock %}

{% block body %}
<div class="min-h-screen bg-gray-50 py-12">
	<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

		{# Header #}
		<div class="mb-8 flex flex-col md:flex-row md:items-center md:justify-between gap-4">
			<div>
				<div class="inline-flex items-center gap-2 px-4 py-2 bg-indigo-100 text-indigo-800 rounded-full text-sm font-medium mb-3">
					<i class="fas fa-shield-alt"></i> Administration
				</div>
				<h1 class="text-4xl font-bold text-gray-900">Gestion des commandes</h1>
				<p class="text-gray-500 mt-1">Suivez et mettez à jour le statut des commandes.</p>
			</div>
			<a href="{{ path('app_admin_index') }}" class="inline-flex items-center gap-2 px-4 py-2 bg-white border border-gray-200 rounded-xl text-sm font-medium text-gray-700 hover:bg-gray-50 transition">
				<i class="fas fa-arrow-left"></i> Dashboard
			</a>
		</div>

		{# Filtres #}
		<div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-4 mb-6 flex flex-wrap gap-2">
			<a href="{{ path('app_admin_commandes') }}"
			   class="px-4 py-2 rounded-xl text-sm font-medium transition {{ filtre_statut == '' ? 'bg-gray-800 text-white' : 'bg-gray-100 text-gray-700 hover:bg-gray-200' }}">
				Toutes
			</a>
			{% set statut_badges = {
				'en_attente': {'label': 'En attente', 'color': 'yellow'},
				'validee': {'label': 'Validées', 'color': 'blue'},
				'expediee': {'label': 'Expédiées', 'color': 'indigo'},
				'livree': {'label': 'Livrées', 'color': 'green'},
				'annulee': {'label': 'Annulées', 'color': 'red'}
			} %}
			{% for s in statuts %}
				{% set badge = statut_badges[s] %}
				<a href="{{ path('app_admin_commandes', {'statut': s}) }}"
				   class="px-4 py-2 rounded-xl text-sm font-medium transition {{ filtre_statut == s ? 'bg-gray-800 text-white' : 'bg-gray-100 text-gray-700 hover:bg-gray-200' }}">
					{{ badge.label }}
				</a>
			{% endfor %}
		</div>

		{# Table commandes #}
		<div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden">
			{% if commandes is empty %}
				<div class="p-16 text-center text-gray-400">
					<i class="fas fa-shopping-cart text-5xl mb-4"></i>
					<p class="text-lg">Aucune commande trouvée.</p>
				</div>
			{% else %}
				<div class="overflow-x-auto">
					<table class="min-w-full divide-y divide-gray-100">
						<thead class="bg-gray-50">
							<tr>
								<th class="px-5 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">#</th>
								<th class="px-5 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Client</th>
								<th class="px-5 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Date</th>
								<th class="px-5 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Total</th>
								<th class="px-5 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Statut</th>
								<th class="px-5 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Action</th>
							</tr>
						</thead>
						<tbody class="divide-y divide-gray-100">
							{% for cmd in commandes %}
								{% set badge = statut_badges[cmd.statut] ?? {'label': cmd.statut, 'color': 'gray'} %}
								<tr class="hover:bg-gray-50 transition">
									<td class="px-5 py-4 text-sm font-mono text-gray-500">#{{ cmd.id }}</td>
									<td class="px-5 py-4">
										<p class="text-sm font-medium text-gray-900">{{ cmd.user.username }}</p>
										<p class="text-xs text-gray-400">{{ cmd.user.email }}</p>
									</td>
									<td class="px-5 py-4 text-sm text-gray-600">{{ cmd.dateCommande|date('d/m/Y') }}</td>
									<td class="px-5 py-4 text-sm font-semibold text-gray-900">{{ cmd.total|number_format(2, ',', ' ') }} €</td>
									<td class="px-5 py-4">
										<span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-medium bg-{{ badge.color }}-100 text-{{ badge.color }}-800">
											{{ badge.label }}
										</span>
									</td>
									<td class="px-5 py-4">
										<form method="post" action="{{ path('app_admin_commande_statut', {'id': cmd.id}) }}" class="flex items-center gap-2">
											<input type="hidden" name="_token" value="{{ csrf_token('admin_commande_' ~ cmd.id) }}">
											<select name="statut" class="text-sm border border-gray-200 rounded-lg px-2 py-1 focus:outline-none focus:ring-2 focus:ring-green-400">
												{% for s in statuts %}
													<option value="{{ s }}" {{ cmd.statut == s ? 'selected' : '' }}>
														{{ statut_badges[s].label ?? s }}
													</option>
												{% endfor %}
											</select>
											<button type="submit" class="px-3 py-1 bg-green-600 text-white text-xs rounded-lg hover:bg-green-700 transition">
												OK
											</button>
										</form>
									</td>
								</tr>
							{% endfor %}
						</tbody>
					</table>
				</div>
			{% endif %}
		</div>

	</div>
</div>
{% endblock %}
