{% extends 'base.html.twig' %}

{% block title %}Paiement réussi — FleurVerte{% endblock %}

{% block body %}
<div class="min-h-screen bg-gray-50 flex items-center justify-center py-16 px-4">
	<div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-10 max-w-md w-full text-center">

		<div class="w-16 h-16 bg-green-100 rounded-2xl flex items-center justify-center mx-auto mb-6">
			<i class="fas fa-check text-green-600 text-2xl"></i>
		</div>

		<h1 class="text-2xl font-bold text-gray-900 mb-2">Paiement réussi !</h1>
		<p class="text-gray-500 mb-8">Merci pour votre commande. Vous recevrez une confirmation par email.</p>

		<a href="{{ path('app_home') }}"
			class="inline-flex items-center gap-2 bg-green-600 hover:bg-green-700 text-white font-semibold py-3 px-8 rounded-xl transition">
			<i class="fas fa-home"></i> Retour à l'accueil
		</a>
	</div>
</div>
{% endblock %}
