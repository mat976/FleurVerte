{% extends 'base.html.twig' %}

{% block title %}Paiement annulé — FleurVerte{% endblock %}

{% block body %}
<div class="min-h-screen bg-gray-50 flex items-center justify-center py-16 px-4">
	<div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-10 max-w-md w-full text-center">

		<div class="w-16 h-16 bg-red-100 rounded-2xl flex items-center justify-center mx-auto mb-6">
			<i class="fas fa-times text-red-500 text-2xl"></i>
		</div>

		<h1 class="text-2xl font-bold text-gray-900 mb-2">Paiement annulé</h1>
		<p class="text-gray-500 mb-8">Votre paiement a été annulé. Aucun montant n'a été débité.</p>

		<div class="flex flex-col sm:flex-row gap-3 justify-center">
			<a href="{{ path('app_checkout') }}" 
				class="inline-flex items-center justify-center gap-2 bg-indigo-600 hover:bg-indigo-700 text-white font-semibold py-3 px-6 rounded-xl transition">
				<i class="fas fa-redo"></i> Réessayer
			</a>
			<a href="{{ path('app_home') }}"
				class="inline-flex items-center justify-center gap-2 bg-gray-100 hover:bg-gray-200 text-gray-700 font-semibold py-3 px-6 rounded-xl transition">
				<i class="fas fa-home"></i> Accueil
			</a>
		</div>
	</div>
</div>
{% endblock %}
