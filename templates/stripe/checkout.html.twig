{% extends 'base.html.twig' %}

{% block title %}Paiement — FleurVerte{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <meta name="turbo-visit-control" content="reload">
{% endblock %}

{% block body %}
<div class="min-h-screen bg-gray-50 flex items-center justify-center py-16 px-4">
	<div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-10 max-w-lg w-full">

		<div class="flex items-center gap-3 mb-8">
			<div class="w-10 h-10 bg-green-100 rounded-xl flex items-center justify-center">
				<i class="fas fa-leaf text-green-600"></i>
			</div>
			<h1 class="text-2xl font-bold text-gray-900">Récapitulatif de commande</h1>
		</div>

		<div class="divide-y divide-gray-100 mb-6">
			{% for item in panier %}
			<div class="flex items-center justify-between py-3">
				<div class="flex items-center gap-3">
					<span class="w-7 h-7 bg-gray-100 rounded-lg flex items-center justify-center text-sm font-semibold text-gray-600">
						{{ item.quantity }}
					</span>
					<span class="text-gray-800 font-medium">{{ item.fleur.nom }}</span>
				</div>
				<span class="text-gray-900 font-semibold">
					{{ (item.fleur.prix * item.quantity)|number_format(2, ',', ' ') }} €
				</span>
			</div>
			{% endfor %}
		</div>

		<div class="bg-green-50 rounded-xl p-4 mb-8 flex items-center justify-between">
			<span class="text-gray-700 font-medium">Total</span>
			<span class="text-2xl font-bold text-green-700">{{ total|number_format(2, ',', ' ') }} €</span>
		</div>

		<form action="{{ path('app_checkout_post') }}" method="POST" data-turbo="false">
			<input type="hidden" name="_token" value="{{ csrf_token('checkout') }}">
			<button type="submit"
				style="width:100%;background:#4f46e5;color:#fff;font-weight:600;padding:1rem 2rem;border-radius:0.75rem;font-size:1.125rem;border:none;cursor:pointer;display:flex;align-items:center;justify-content:center;gap:0.75rem;"
				onmouseover="this.style.background='#4338ca'" onmouseout="this.style.background='#4f46e5'">
				<i class="fab fa-stripe-s"></i>
				Payer {{ total|number_format(2, ',', ' ') }} € avec Stripe
			</button>
		</form>

		<div class="mt-4 flex items-center justify-between text-sm text-gray-400">
			<div class="flex items-center gap-1">
				<i class="fas fa-lock"></i>
				<span>Paiement chiffré SSL</span>
			</div>
			<a href="{{ path('app_cart_index') }}" class="hover:text-gray-600 transition">
				<i class="fas fa-arrow-left mr-1"></i> Retour au panier
			</a>
		</div>
	</div>
</div>
{% endblock %}
